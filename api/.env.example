# Database — PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trace

# Logging level — DEBUG for dev, INFO for prod
LOG_LEVEL=DEBUG

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Proxy headers — set to true if behind a reverse proxy (nginx, etc.)
TRUST_PROXY_HEADERS=false

# Google OAuth — obtain from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# Frontend URL — used for OAuth redirect
FRONTEND_URL=http://localhost:5173
